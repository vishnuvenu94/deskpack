{
  "name": "deskpack",
  "version": "0.1.0-beta.1",
  "description": "Package JavaScript frontend and full-stack Node apps into desktop applications",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "deskpack": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "node ./scripts/clean-dist.mjs && tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "lint": "tsc --noEmit",
    "test": "npm run build && node --test \"test/**/*.test.mjs\"",
    "check:naming": "node ./scripts/check-legacy-name.mjs",
    "check:release": "npm run check:naming && npm run lint && npm run test && npm pack --dry-run --cache ./.npm-cache && node ./scripts/validate-bin.mjs && node ./scripts/validate-version.mjs",
    "check:publish": "npm run check:release && npm audit && npm publish --dry-run --tag beta --access public --cache ./.npm-cache"
  },
  "keywords": [
    "deskpack",
    "electron",
    "desktop",
    "cli",
    "full-stack",
    "frontend",
    "backend",
    "cross-platform",
    "javascript",
    "nodejs",
    "packaging",
    "nextjs",
    "vite",
    "angular",
    "hono",
    "express"
  ],
  "author": "Deskpack contributors",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "esbuild": "^0.25.0",
    "fast-glob": "^3.3.3",
    "ora": "^8.2.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.7.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vishnuvenu94/deskpack.git"
  },
  "homepage": "https://github.com/vishnuvenu94/deskpack#readme",
  "bugs": {
    "url": "https://github.com/vishnuvenu94/deskpack/issues"
  },
  "publishConfig": {
    "access": "public",
    "tag": "beta"
  }
}
